# ==============================
# 🌈 Mood Tracker Application
# ==============================

# ⚙️ Ports
PORT_1=8081        # Auth Service
PORT_2=8082        # Mood Service
PORT_3=8083        # Blog Service
PORT_4=8084        # Notification Service

# 🗄️ Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=moodtracker

# 🚀 Hasura
HASURA_GRAPHQL_ADMIN_SECRET=hasura_secret
HASURA_GRAPHQL_ENDPOINT=http://hasura:8080/v1/graphql

# 🧑‍💻 PgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# 🔐 JWT
JWT_SECRET=supersecretkey

# 🌐 Google OAuth2
GOOGLE_CLIENT_ID=554001001762-evs2kjr8fsaco76ih0ro842kenc5j5mj.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URL=http://localhost:8081/auth/google/callback

# 💌 Email Verification (Resend)
RESEND_API_KEY=re_LJTmRbUA_H5f2aeFfCo1g3o6j7YojDRXw
PUBLIC_BASE_URL=http://localhost:8081

# 🧠 Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ==============================
# 🔔 Notification Service
# ==============================

# Service Port
NOTIFICATION_PORT=${PORT_4}

# Redis connection for pub/sub (shared with other services)
NOTIFICATION_REDIS_ADDR=redis:6379

# Hasura persistence (optional)
NOTIFICATION_HASURA_ENDPOINT=${HASURA_GRAPHQL_ENDPOINT}
NOTIFICATION_HASURA_ADMIN_SECRET=${HASURA_GRAPHQL_ADMIN_SECRET}

# JWT (shared with auth-service)
NOTIFICATION_JWT_SECRET=${JWT_SECRET}

# ==============================
# 📱 Push Notifications (Firebase HTTP v1)
# ==============================
# Path to the Firebase service account key (JSON)
GOOGLE_APPLICATION_CREDENTIALS=../keys/firebase-service-account.json
FIREBASE_PROJECT_ID=gm-app-b83d7

# Enable or disable push notifications
ENABLE_PUSH=true

# ==============================
# 💌 Email Notifications (SendGrid)
# ==============================
SENDGRID_API_KEY=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
ENABLE_EMAIL=false

# ==============================
# ✅ Notes
# ==============================
# - For Firebase: generate a Service Account key from Firebase Console > Project Settings > Service Accounts
#   and save it as ./notification-service/keys/firebase-service-account.json
# - Do NOT use legacy FCM_SERVER_KEY anymore (deprecated)
# - For SendGrid: create an API key at https://app.sendgrid.com/settings/api_keys
# - Set ENABLE_PUSH=true or ENABLE_EMAIL=true as needed
# - Notifications are sent in real time via Redis Pub/Sub
# - Hasura persistence optional for historical data
